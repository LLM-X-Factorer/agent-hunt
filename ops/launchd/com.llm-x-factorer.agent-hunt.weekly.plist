<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.llm-x-factorer.agent-hunt.weekly</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-c</string>
        <string>/Users/liu/Projects/agent-hunt/ops/weekly_refresh.sh</string>
    </array>

    <!-- Every Sunday at 02:00 local time -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>0</integer>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <!-- Don't run when the system first loads the plist; only on schedule -->
    <key>RunAtLoad</key>
    <false/>

    <!-- Catch up on missed runs (e.g. mac was off Sunday 02:00) -->
    <key>StartCalendarIntervalAcceptsMissedRuns</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/liu/Library/Logs/agent-hunt/launchd-weekly-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/liu/Library/Logs/agent-hunt/launchd-weekly-stderr.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/liu/Projects/agent-hunt</string>
</dict>
</plist>
