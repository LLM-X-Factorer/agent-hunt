# ============================================================
# Agent Hunt — Environment Variables
# Copy to .env and fill in your values
# ============================================================

# --- Database (PostgreSQL) ---
# Option A: cloud-hosted (Supabase / Neon). Set the full URL — wins over
# the split fields below.
# AH_DATABASE_URL_OVERRIDE=postgresql://postgres.xxx:password@aws-0-us-west-1.pooler.supabase.com:5432/postgres

# Option B: local docker-compose (default for dev)
AH_POSTGRES_USER=agent_hunt
AH_POSTGRES_PASSWORD=agent_hunt_dev
AH_POSTGRES_HOST=localhost
AH_POSTGRES_PORT=5432
AH_POSTGRES_DB=agent_hunt

# --- Redis ---
AH_REDIS_HOST=localhost
AH_REDIS_PORT=6379
AH_REDIS_DB=0

# --- LLM provider (OpenRouter, required for JD parsing) ---
# Get a key at https://openrouter.ai. One key = many models.
AH_OPENROUTER_API_KEY=your-openrouter-api-key
# Examples: z-ai/glm-5.1 (default) | moonshotai/kimi-k2.6 | google/gemini-2.5-flash
AH_LLM_MODEL=z-ai/glm-5.1

# --- Legacy Gemini direct (kept for scripts/compare_llm_providers.py only) ---
AH_GEMINI_API_KEY=
AH_GEMINI_MODEL=gemini-2.5-flash

# --- App ---
AH_DEBUG=false

# --- Currency conversion (fixed rates, CNY as base) ---
AH_USD_TO_CNY=7.25
AH_EUR_TO_CNY=7.90

# --- Docker Compose overrides ---
POSTGRES_USER=agent_hunt
POSTGRES_PASSWORD=agent_hunt_dev
POSTGRES_DB=agent_hunt
POSTGRES_PORT=5432
REDIS_PORT=6379
