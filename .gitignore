# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# Node
node_modules/
.next/
out/

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Docker
docker-compose.override.yml

# Cookies (sensitive, per-user)
data/*_cookies.json

# Temp files (LLM comparison output, etc.)
tmp_*.json
tmp_*.txt

# Playwright MCP runtime cache
.playwright-mcp/

# DB backups (potentially containing sensitive data)
backups/

# Claude Code local state (scheduled task lock, agent runtime)
.claude/

# Personal resumes / sensitive PII (per-user, never commit)
docs/employee-resume/

# Probe scripts — 一次性探查脚本，不可达数据源验证用
# probe_jd_liveness.py 已 tracked（ghost listing 检测主流程），保留
backend/scripts/probe_*.py
!backend/scripts/probe_jd_liveness.py
